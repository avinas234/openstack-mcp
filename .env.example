# ==============================================================================
# OpenStack MCP Server — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All settings have sensible defaults where possible.
# Lines starting with # are comments and are ignored.
# ==============================================================================

# ── SSH Connection ───────────────────────────────────────────────────────────
# The MCP server connects to your OpenStack controller node via SSH.

# Hostname or IP address of the OpenStack controller
OPENSTACK_HOST=localhost

# SSH port (default: 22)
OPENSTACK_SSH_PORT=22

# SSH username (REQUIRED — no default)
OPENSTACK_SSH_USER=

# SSH password (provide either password or key file)
OPENSTACK_SSH_PASSWORD=

# Path to SSH private key file (alternative to password)
# OPENSTACK_SSH_KEY_FILE=~/.ssh/id_rsa

# Command timeout in seconds (default: 60)
OPENSTACK_TIMEOUT=60


# ── OpenStack RC File ────────────────────────────────────────────────────────
# If you have an admin-openrc.sh file on the controller, set its path here.
# When set, this file is sourced instead of the individual OS_* variables below.
# OPENSTACK_RC_FILE=/etc/kolla/admin-openrc.sh


# ── OpenStack Credentials ───────────────────────────────────────────────────
# These are used only if OPENSTACK_RC_FILE is not set.
# They correspond to the standard OpenStack environment variables.

OS_PROJECT_DOMAIN_NAME=Default
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_NAME=admin
OS_USERNAME=admin
OS_PASSWORD=
OS_AUTH_URL=http://localhost:5000/v3
OS_INTERFACE=internal
OS_ENDPOINT_TYPE=internalURL
OS_IDENTITY_API_VERSION=3
OS_REGION_NAME=RegionOne
OS_AUTH_PLUGIN=password
OS_CACERT=/etc/ssl/certs/ca-certificates.crt


# ── Log Retrieval Settings ──────────────────────────────────────────────────
# How the get_service_logs tool retrieves logs.
#
# "docker" — for Kolla-Ansible or containerized deployments (uses docker logs)
# "file"   — for DevStack or packaged deployments (reads /var/log/<service>/)
OPENSTACK_LOG_SOURCE=docker

# Base path for log files (only used when LOG_SOURCE=file)
OPENSTACK_LOG_PATH=/var/log
